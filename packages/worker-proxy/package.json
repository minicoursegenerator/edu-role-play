{
  "name": "@edu-role-play/worker-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker that proxies Workers AI calls for bundled role-plays (adds CORS + holds the account token).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "secret:token": "wrangler secret put CF_API_TOKEN",
    "secret:account": "wrangler secret put CF_ACCOUNT_ID",
    "types": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.80.0"
  }
}
