    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minicoursegenerator/edu-role-play.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/minicoursegenerator/edu-role-play#readme",
  "bugs": "https://github.com/minicoursegenerator/edu-role-play/issues",
  "keywords": [
