{
  "name": "edu-role-play",
  "version": "0.1.8",
  "description": "CLI for edu-role-play: init, preview, lint, bundle.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "edu-role-play": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minicoursegenerator/edu-role-play.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/minicoursegenerator/edu-role-play#readme",
  "bugs": "https://github.com/minicoursegenerator/edu-role-play/issues",
  "keywords": [
    "edu-role-play",
    "role-play",
    "education",
    "agent-skills",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync-templates": "node scripts/sync-templates.mjs",
    "build": "npm run sync-templates && tsc -p tsconfig.json && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@edu-role-play/core": "0.1.0",
    "@edu-role-play/runtime": "0.1.4",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5"
  }
}
