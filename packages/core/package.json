  "description": "Composition parser, linter rules, and types for edu-role-play.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./parser": "./dist/parser.js",
    "./linter": "./dist/linter.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
